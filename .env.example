# ============================================================
# Internship Outreach Pipeline — Environment Variables
# ============================================================

# Hunter.io — Email finder + verifier (free: 25 finder + 50 verifier/month)
# Get your key at: https://hunter.io/api-keys
HUNTER_API_KEY=your-hunter-api-key-here

# Gmail — SMTP sending via App Password
# Enable 2FA: https://myaccount.google.com/security
# Create App Password: https://myaccount.google.com/apppasswords
GMAIL_ADDRESS=your-email@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Abstract API — Email reputation verifier (free: 100 verifications/month)
# Get your key at: https://app.abstractapi.com/
ABSTRACT_API_KEY=your-abstract-api-key-here
ABSTRACT_API_KEY_2=your-second-abstract-key-here
